{
  "name": "portfolio",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run images && next build",
    "test": "jest --transformIgnorePatterns \"node_modules/(?!your-module-name)/\"",
    "test:watch": "jest --watch",
    "start": "next start -p 4400",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "images": "node scripts/build-image-assets.mjs",
    "zip": "python scripts/zip_standalone.py",
    "deploy:dev": "npm run build && npm run zip && serverless deploy --stage dev",
    "deploy:prod": "npm run build && npm run zip && serverless deploy --stage prod"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@types/node": "^26.1.1",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "gray-matter": "^4.0.3",
    "next": "^16.2.10",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.35.3",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.17",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.5.16",
    "serverless": "^3.40.0",
    "serverless-cloudfront-invalidate": "^1.12.2",
    "serverless-s3-sync": "^3.5.1",
    "tailwindcss": "^4.3.2"
  },
  "overrides": {
    "postcss": "^8.5.16"
  }
}
