{
  "name": "portfolio",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "test": "jest --transformIgnorePatterns \"node_modules/(?!your-module-name)/\"",
    "test:watch": "jest --watch",
    "start": "next start -p 4400",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "zip": "python scripts/zip_standalone.py",
    "deploy:dev": "npm run build && npm run zip && serverless deploy --stage dev",
    "deploy:prod": "npm run build && npm run zip && serverless deploy --stage prod"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@types/node": "25.3.2",
    "@types/react-dom": "19.2.3",
    "eslint": "10.0.2",
    "eslint-config-next": "16.1.6",
    "gray-matter": "^4.0.3",
    "next": "^16.1.6",
    "next-mdx-remote": "^5.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-intersection-observer": "^10.0.3",
    "react-markdown": "^10.1.0",
    "react-spring": "^10.0.3",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.4.27",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.6",
    "serverless": "^3.40.0",
    "serverless-cloudfront-invalidate": "^1.12.2",
    "serverless-s3-sync": "^3.4.0",
    "tailwindcss": "^3.4.17"
  }
}
